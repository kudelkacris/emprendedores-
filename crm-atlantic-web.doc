<title>CRM Atlantic Web</title>
<style>
  body { font-family: Calibri, Arial, sans-serif; font-size: 10pt; margin: 1.5cm; color: #111; }
  h1 { font-size: 18pt; color: #c9a84c; border-bottom: 3px solid #c9a84c; padding-bottom: 6px; margin-bottom: 4px; }
  h2 { font-size: 12pt; color: #111; margin-top: 22px; border-left: 4px solid #c9a84c; padding-left: 8px; }
  .subtitulo { color: #555; font-size: 10pt; margin-bottom: 16px; }

  table { border-collapse: collapse; width: 100%; margin: 10px 0 20px 0; font-size: 9.5pt; }
  th { background: #111010; color: #c9a84c; padding: 7px 8px; text-align: left; font-size: 9pt; border: 1px solid #333; }
  td { border: 1px solid #ccc; padding: 6px 8px; vertical-align: top; }
  tr:nth-child(even) td { background: #f5f5f5; }

  .estado-contactar { background: #fff3cd; color: #856404; font-weight: bold; padding: 2px 6px; border-radius: 3px; }
  .estado-contactado { background: #d1ecf1; color: #0c5460; font-weight: bold; padding: 2px 6px; border-radius: 3px; }
  .estado-interesado { background: #d4edda; color: #155724; font-weight: bold; padding: 2px 6px; border-radius: 3px; }
  .estado-adn { background: #e2d9f3; color: #432874; font-weight: bold; padding: 2px 6px; border-radius: 3px; }
  .estado-propuesta { background: #ffd6a5; color: #7d4400; font-weight: bold; padding: 2px 6px; border-radius: 3px; }
  .estado-cliente { background: #111010; color: #c9a84c; font-weight: bold; padding: 2px 6px; border-radius: 3px; }
  .estado-descartado { background: #f8d7da; color: #721c24; font-weight: bold; padding: 2px 6px; border-radius: 3px; }

  .linea { border-bottom: 1px solid #bbb; min-height: 14px; margin: 2px 0; }
  .ref-box { background: #fafafa; border: 1px solid #e0e0e0; padding: 10px 14px; margin: 8px 0; font-size: 9pt; }
  .ref-box strong { display: inline-block; width: 120px; }
  hr { border: none; border-top: 1px solid #ddd; margin: 18px 0; }
  .pie { color: #999; font-size: 8.5pt; text-align: center; margin-top: 20px; }
  .mensaje-wpp { background: #e8f5e9; border-left: 4px solid #4caf50; padding: 8px 12px; font-size: 9pt; margin: 6px 0; }
  .col-estado { width: 100px; }
  .col-fecha { width: 70px; }
  .col-monto { width: 70px; }
  .col-canal { width: 80px; }
</style>
</head>
